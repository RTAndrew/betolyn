meta {
  name: create AUTO event
  type: http
  seq: 1
}

docs {
  Links a feed (official) match to the space by creating a derived row. Response data is a MatchDTO with type "DERIVED" and officialMatchId set to the feed match id (merged view).
}

post {
  url: {{baseUrl}}/spaces/{{spaceId}}/matches
  body: json
  auth: inherit
}

body:json {
  {
    "matchId": "{{matchId}}",
    "maxReservedLiability": 1000
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
