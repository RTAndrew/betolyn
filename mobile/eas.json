{
	"cli": {
		"version": ">= 16.26.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"environment": "development",
			"developmentClient": true,
			"distribution": "internal",
			"env": {
				"APP_VARIANT": "development",
				"EXPO_PUBLIC_BACKEND_API_URL": "https://api.betolyn.com"
			}
		},
		"preview": {
			"environment": "preview",
			"distribution": "internal",
			"env": {
				"APP_VARIANT": "preview",
				"EXPO_PUBLIC_BACKEND_API_URL": "https://api.betolyn.com"
			},
			"android": {
				"buildType": "apk"
			}
		},
		"production": {
			"environment": "production",
			"autoIncrement": true,
			"env": {
				"APP_VARIANT": "production",
				"EXPO_PUBLIC_BACKEND_API_URL": "https://api.betolyn.com"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
