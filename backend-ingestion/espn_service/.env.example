# Copy this file next to it as `.env` and adjust values:
#   cp .env.example .env
#
# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database
# Docker Compose publishes Postgres on the host at port 5433 by default (override with ESPN_DB_HOST_PORT).
#
# • espn_service/docker-compose.yml → DB name espn_service, user espn / password espn
# • espn-api/docker-compose.yml (repo root) → DB name espn_db, user postgres / password postgres
#
# Use these when Django / Celery run on your host (not inside Compose):
DATABASE_URL=postgres://espn:espn@localhost:5433/espn_service
# Root compose stack from espn-api/:
# DATABASE_URL=postgres://postgres:postgres@localhost:5433/espn_db

# Redis / Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/1
# Use false when a real Celery worker consumes Redis (docker-compose sets this for web/worker/beat).
CELERY_TASK_ALWAYS_EAGER=false

# Allowlist Beat jobs: fan-out stagger (seconds between chain/task starts; default 600 = 10 min)
ALLOWLIST_FANOUT_STAGGER_SECONDS=600
# Max allowlist rows enqueued per daily horizon run (0 = no limit)
ALLOWLIST_FANOUT_MAX_CHAINS_PER_RUN=0
# Seconds added to orchestrator "now" before first chain ETA
ALLOWLIST_FANOUT_FIRST_SLOT_OFFSET_SECONDS=0
ALLOWLIST_TEAMS_FANOUT_STAGGER_SECONDS=600
ALLOWLIST_TEAMS_FANOUT_MAX_TASKS_PER_RUN=0
# Route refresh_scoreboard_task / refresh_teams_task to queue "ingest" (worker needs -Q celery,ingest)
CELERY_ROUTE_INGEST_TO_QUEUE=false

# ESPN Client
ESPN_SITE_API_URL=https://site.api.espn.com
ESPN_CORE_API_URL=https://sports.core.api.espn.com
ESPN_TIMEOUT=30.0
ESPN_MAX_RETRIES=3
ESPN_RETRY_BACKOFF=1.0
ESPN_USER_AGENT=ESPN-Service/1.0

# Logging
LOGGING_LEVEL=INFO

# Optional: Sentry (for production error tracking)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
ENVIRONMENT=development
