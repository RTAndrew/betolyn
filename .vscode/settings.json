{
	"cursorpyright.analysis.autoImportCompletions": true,
	"cursorpyright.analysis.autoSearchPaths": true,
	"cursorpyright.analysis.extraPaths": ["./backend"],
	"cursorpyright.analysis.typeCheckingMode": "basic",
	"java.configuration.updateBuildConfiguration": "automatic",
	"java.compile.nullAnalysis.mode": "automatic",
	"[java]": {
		"editor.defaultFormatter": "redhat.java"
	},

	// JavaScript/TypeScript
	"editor.defaultFormatter": "oxc.oxc-vscode",
	"editor.codeActionsOnSave": {
		"source.fixAll": "explicit",
		"source.fixAll.oxc": "explicit",
		"source.organizeImports": "explicit",
		"source.sortMembers": "explicit"
	},
	"oxc.fixKind": "dangerous_fix_or_suggestion",
	"oxc.fmt.configPath": ".oxfmtrc.json",
	"[javascript]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"[javascriptreact]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"[typescript]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"workbench.editor.customLabels.patterns": {
		"**/**/index.js": "${dirname} → index.js",
		"**/**/index.ts": "${dirname} → index.ts",
		"**/**/index.tsx": "${dirname} → index.tsx",
		"**/**/styles.tsx": "${dirname} → styles.tsx"
	}
}
