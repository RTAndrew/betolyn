# Copy to .env in this directory (project root, next to docker-compose.yml)
# cp .env.example .env

# --- External Postgres (e.g. Neon prod) — backend uses these instead of the local postgres service ---
# SPRING_DATASOURCE_URL=jdbc:postgresql://HOST/DB?sslmode=require&connect_timeout=10
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=
# First deploy only (empty DB): create-only. After schema exists, switch to validate.
# SPRING_JPA_HIBERNATE_DDL_AUTO=create-only

POSTGRES_USER=betolyn
POSTGRES_PASSWORD=betolyn
POSTGRES_PORT=5432
# Use 6380 if another Compose stack already binds host :6379 (e.g. backend-ingestion/redis).
REDIS_PORT=6379
BACKEND_PORT=8080

# Pull teams/events from espn_service into Betolyn (override URL if ingestion is elsewhere)
# APP_INGESTION_ENABLED=true
# APP_INGESTION_RUN_ON_STARTUP=true
# ESPN_SERVICE_BASE_URL=http://host.docker.internal:8010

# Required in production: use a long random secret
# Names below must match Spring Boot env binding (no extra underscores in the middle)
APP_AUTH_JWTSECRET=your-secret-here
APP_AUTH_SESSIONEXPIRATIONINDAYS=7
APP_AUTH_COOKIESTOKENNAMEKEY=token
APP_CORS_ALLOWEDORIGINS=http://localhost:8001


# For Render.com (set these in the Render dashboard, not for docker compose)
# Render usually injects these automatically when you attach Postgres / Redis.
# They are shown here as documentation of what the app understands:
#
# DATABASE_URL=postgresql://user:password@hostname:5432/database
# REDIS_URL=redis://hostname:6379
