# Copy to .env in this directory (project root, next to docker-compose.yml)
# cp .env.example .env

POSTGRES_USER=betolyn
POSTGRES_PASSWORD=betolyn
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8080

# Required in production: use a long random secret
# Names below must match Spring Boot env binding (no extra underscores in the middle)
APP_AUTH_JWTSECRET=your-secret-here
APP_AUTH_SESSIONEXPIRATIONINDAYS=7
APP_AUTH_COOKIESTOKENNAMEKEY=token
APP_CORS_ALLOWEDORIGINS=http://localhost:8001


# For Render.com (set these in the Render dashboard, not for docker compose)
# Render usually injects these automatically when you attach Postgres / Redis.
# They are shown here as documentation of what the app understands:
#
# DATABASE_URL=postgresql://user:password@hostname:5432/database
# REDIS_URL=redis://hostname:6379
